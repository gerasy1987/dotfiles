#!/usr/bin/env sh
set -eu

# Canonical location of VS Code settings within this dotfiles repo
DOTFILES_VSCODE="${HOME}/dotfiles/vscode/.config/Code/User"

# Determine the OS-specific VS Code User directory
case "$(uname -s)" in
  Darwin)
    VSCODE_USER="${HOME}/Library/Application Support/Code/User"
    ;;
  Linux)
    VSCODE_USER="${HOME}/.config/Code/User"
    ;;
  *)
    printf 'Unsupported OS: %s\n' "$(uname -s)" >&2
    exit 1
    ;;
esac

mkdir -p "${VSCODE_USER}"

for file in settings.json keybindings.json; do
  src="${DOTFILES_VSCODE}/${file}"
  dst="${VSCODE_USER}/${file}"

  if [ ! -f "$src" ]; then
    printf 'Source not found: %s\n' "$src" >&2
    continue
  fi

  if [ -L "$dst" ]; then
    # Already a symlink — replace it
    rm "$dst"
  elif [ -f "$dst" ]; then
    printf 'Backing up %s -> %s.bak\n' "$dst" "$dst"
    mv "$dst" "${dst}.bak"
  fi

  ln -s "$src" "$dst"
  printf 'Linked %s -> %s\n' "$dst" "$src"
done
